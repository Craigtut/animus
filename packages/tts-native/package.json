{
  "name": "@animus-labs/tts-native",
  "version": "0.2.1",
  "license": "MIT",
  "private": true,
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "name": "tts-native",
    "triples": {
      "defaults": false,
      "additional": [
        "aarch64-apple-darwin",
        "x86_64-apple-darwin",
        "x86_64-unknown-linux-gnu",
        "aarch64-unknown-linux-gnu"
      ]
    }
  },
  "scripts": {
    "build": "napi build --release --platform",
    "build:debug": "napi build --platform"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0"
  }
}
