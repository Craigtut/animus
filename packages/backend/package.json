{
  "name": "@animus-labs/backend",
  "version": "0.2.2",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=../../.env --conditions source src/index.ts",
    "build": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json && node -e \"fs.cpSync('src/db/migrations','dist/db/migrations',{recursive:true})\" && node -e \"fs.writeFileSync('dist/version.json',JSON.stringify({version:JSON.parse(fs.readFileSync('package.json','utf8')).version}))\" && npm run build:frontend",
    "build:frontend": "node -e \"try{fs.cpSync('../frontend/dist','./dist/public',{recursive:true})}catch{console.log('Frontend not built yet')}\"",
    "start": "node --env-file-if-exists=../../.env dist/index.js",
    "sandbox": "tsx --env-file-if-exists=../../.env --conditions source src/sandbox/index.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@animus-labs/agents": "*",
    "@animus-labs/shared": "*",
    "@animus-labs/tts-native": "*",
    "@fastify/cookie": "^10.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^8.0.0",
    "@fastify/websocket": "^11.0.0",
    "@huggingface/transformers": "^3.8.1",
    "@lancedb/lancedb": "^0.26.2",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@openai/codex-sdk": "^0.87.0",
    "@trpc/server": "^11.0.0",
    "@types/archiver": "^7.0.0",
    "archiver": "^7.0.1",
    "argon2": "^0.44.0",
    "better-sqlite3": "^11.0.0",
    "cron-parser": "^5.5.0",
    "extract-zip": "^2.0.1",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.1.0",
    "ink": "^6.7.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "llm-json-stream": "^1.1.0",
    "picocolors": "^1.1.1",
    "posthog-node": "^5.26.2",
    "react": "^19.2.4",
    "sherpa-onnx-node": "^1.12.25",
    "tar": "^7.5.9",
    "unbzip2-stream": "^1.4.3",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.25.1"
  },
  "optionalDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/react": "^19.2.14",
    "@types/unbzip2-stream": "^1.4.3",
    "tsx": "^4.19.0"
  }
}
