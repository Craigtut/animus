{
  "name": "@animus/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && npm run build:frontend",
    "build:frontend": "cp -r ../frontend/dist ./dist/public 2>/dev/null || echo 'Frontend not built yet'",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@animus/agents": "*",
    "@animus/shared": "*",
    "@fastify/cookie": "^10.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/static": "^8.0.0",
    "@fastify/websocket": "^11.0.0",
    "@lancedb/lancedb": "^0.24.1",
    "@trpc/server": "^11.0.0",
    "better-sqlite3": "^11.0.0",
    "fastify": "^5.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "tsx": "^4.19.0"
  }
}
