{
  "name": "@animus/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch --conditions source src/index.ts",
    "build": "tsc && npm run build:frontend",
    "build:frontend": "cp -r ../frontend/dist ./dist/public 2>/dev/null || echo 'Frontend not built yet'",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@animus/agents": "*",
    "@animus/shared": "*",
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "@fastify/cookie": "^10.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/static": "^8.0.0",
    "@fastify/websocket": "^11.0.0",
    "@huggingface/transformers": "^3.8.1",
    "@lancedb/lancedb": "^0.26.2",
    "@trpc/server": "^11.0.0",
    "argon2": "^0.44.0",
    "better-sqlite3": "^11.0.0",
    "cron-parser": "^5.5.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.1.0",
    "llm-json-stream": "^1.1.0",
    "picocolors": "^1.1.1",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "tsx": "^4.19.0"
  }
}
