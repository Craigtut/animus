{
  "name": "@animus-labs/agents",
  "version": "0.3.1",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && node -e \"require('fs').cpSync('src/models.json','dist/models.json')\"",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@animus-labs/shared": "*",
    "zod": "^4.0.0"
  },
  "peerDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.0",
    "@openai/codex-sdk": "^0.87.0",
    "@opencode-ai/sdk": "^1.1.23"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/claude-agent-sdk": {
      "optional": true
    },
    "@openai/codex-sdk": {
      "optional": true
    },
    "@opencode-ai/sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.0",
    "@openai/codex-sdk": "^0.87.0",
    "@opencode-ai/sdk": "^1.1.23",
    "@types/node": "^22.0.0",
    "vitest": "^2.1.0"
  }
}
