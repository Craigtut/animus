{
  "identifier": "default",
  "description": "Default capabilities for the Animus desktop app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "shell:allow-spawn",
    "shell:allow-execute",
    "shell:allow-open",
    "autostart:allow-enable",
    "autostart:allow-disable",
    "autostart:allow-is-enabled"
  ]
}
