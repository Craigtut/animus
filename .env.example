# Animus Environment Configuration
# Copy this file to .env and fill in your values
#
# NOTE: Most variables have sensible defaults. API keys can also be
# configured through the UI (Settings > API Keys) where they're stored
# encrypted in the database.

# =============================================================================
# Server Configuration
# =============================================================================

NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# =============================================================================
# Database Paths (relative to the backend package directory)
# =============================================================================

# DB_SYSTEM_PATH=./data/system.db
# DB_HEARTBEAT_PATH=./data/heartbeat.db
# DB_MEMORY_PATH=./data/memory.db
# DB_MESSAGES_PATH=./data/messages.db
# DB_AGENT_LOGS_PATH=./data/agent_logs.db
# LANCEDB_PATH=./data/lancedb

# =============================================================================
# Authentication
# =============================================================================

# IMPORTANT: Change this in production!
JWT_SECRET=change-me-in-production

# Session expiration in days
# SESSION_EXPIRY_DAYS=7

# =============================================================================
# Encryption (REQUIRED)
# =============================================================================

# Used to encrypt API keys and secrets stored in the database (AES-256-GCM).
# Set this to any secret string. The server will not start without it.
# IMPORTANT: Do not change this after first run — existing encrypted data
# becomes unreadable if the key changes.
ANIMUS_ENCRYPTION_KEY=

# =============================================================================
# Agent API Keys (optional - can also be configured in Settings UI)
# =============================================================================

# Anthropic API key for Claude Agent SDK
# Get yours at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=

# OpenAI API key for Codex SDK
# Get yours at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=
