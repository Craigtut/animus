# Animus Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Server Configuration
# =============================================================================

NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# =============================================================================
# Database Paths
# =============================================================================

# Paths are relative to the backend package directory
DB_SYSTEM_PATH=./data/system.db
DB_HEARTBEAT_PATH=./data/heartbeat.db
DB_AGENT_LOGS_PATH=./data/agent_logs.db
LANCEDB_PATH=./data/lancedb

# =============================================================================
# Heartbeat Configuration
# =============================================================================

# Interval between heartbeat ticks in milliseconds (default: 5 minutes)
HEARTBEAT_INTERVAL_MS=300000

# =============================================================================
# Authentication
# =============================================================================

# IMPORTANT: Change this in production!
JWT_SECRET=change-me-in-production

# Session expiration in days
SESSION_EXPIRY_DAYS=7

# =============================================================================
# Agent API Keys
# =============================================================================

# Anthropic API key for Claude Agent SDK
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI API key for Codex SDK
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenCode API configuration (if using OpenCode SDK)
# See: https://opencode.ai/docs/
