# =============================================================================
# Animus Engine — Environment Configuration
# =============================================================================
# Copy this file to .env and customize as needed.
# Most settings have sensible defaults; only ANTHROPIC_API_KEY is required.

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------

# Runtime environment: "development" or "production"
NODE_ENV=development

# Port the backend listens on
PORT=3000

# Bind address (use 0.0.0.0 for Docker/remote access)
HOST=localhost

# Log level: debug | info | warn | error
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Data Directory
# -----------------------------------------------------------------------------

# Where databases, models, logs, and media are stored.
# Defaults to ./data relative to the backend package.
# In Docker this is set to /app/data (mapped to a volume).
# ANIMUS_DATA_DIR=./data

# -----------------------------------------------------------------------------
# API Keys
# -----------------------------------------------------------------------------

# Anthropic API key (required for Claude agent, the default provider).
# Can also be configured via the Settings UI after first launch.
ANTHROPIC_API_KEY=

# OpenAI API key (optional, only needed if using the Codex agent provider).
# OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------

# How long login sessions last before requiring re-authentication (days).
# SESSION_EXPIRY_DAYS=30

# -----------------------------------------------------------------------------
# Auto-Generated Secrets (DO NOT set manually)
# -----------------------------------------------------------------------------
# The following are generated automatically on first run and stored in
# data/secrets.json. Do not set them here; they will be ignored.
#
#   ANIMUS_ENCRYPTION_KEY  -- AES-256-GCM key for encrypting credentials at rest
#   JWT_SECRET             -- HMAC key for signing auth tokens
