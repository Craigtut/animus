# Animus Environment Configuration
# Copy this file to .env and customize as needed.
# Most settings have sensible defaults — you can start with an empty .env file.

# =============================================================================
# Data Directory
# =============================================================================
# All persistent data (databases, media, models, logs, secrets) lives here.
# Default: ./data/ relative to project root
# ANIMUS_DATA_DIR=./data

# =============================================================================
# Server Configuration
# =============================================================================

NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Session expiration in days
# SESSION_EXPIRY_DAYS=7

# =============================================================================
# Secrets (auto-generated)
# =============================================================================
# On first run, Animus auto-generates an encryption key and JWT secret,
# stored in $ANIMUS_DATA_DIR/.secrets (file permissions 0600).
#
# You can override with env vars if needed (e.g., migrating between hosts):
# ANIMUS_ENCRYPTION_KEY=your-64-char-hex-key
# JWT_SECRET=your-64-char-hex-secret
#
# WARNING: Changing the encryption key after initial setup will make all
# stored credentials (API keys, channel configs) unreadable.

# =============================================================================
# Agent API Keys (optional — can also be configured in Settings UI)
# =============================================================================

# Anthropic API key for Claude Agent SDK
# Get yours at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=

# OpenAI API key for Codex SDK
# Get yours at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=
